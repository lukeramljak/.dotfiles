{
  "which_key": {
    "enabled": true
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "semantic_tokens": "combined",
  "buffer_line_height": "comfortable",
  "ssh_connections": [
    {
      "host": "devbox",
      "args": [],
      "port_forwards": [
        {
          "local_port": 3000,
          "remote_port": 3000
        },
        {
          "local_port": 3001,
          "remote_port": 3001
        },
        {
          "local_port": 5173,
          "remote_port": 5173
        }
      ],
      "projects": [
        {
          "paths": [
            "/home/luke/dev/work/odin"
          ]
        },
        {
          "paths": [
            "/home/luke/dev/work/calculator-BE"
          ]
        },
        {
          "paths": [
            "/home/luke/dev/work/calculator-FE"
          ]
        }
      ]
    }
  ],
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "prettier": {
    "allowed": false
  },
  "show_edit_predictions": false,
  "icon_theme": "Zed (Default)",
  "theme": "Vague",
  "ui_font_family": "BerkeleyMono Nerd Font",
  "buffer_font_family": "BerkeleyMono Nerd Font",
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "format_on_save": "on",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "tab_bar": {
    "show": true
  },
  "indent_guides": {
    "enabled": true
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },
  "languages": {
    "JavaScript": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TypeScript": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    }
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": [
          "cn",
          "cva",
          "clsx",
          "mergeStyling",
          "useResolveClassNames"
        ],
        "experimental": {
          "classRegex": [
            "[a-z]*[Cc]lassName\\s*[=:]\\s*\"([^\"]*)\""
          ]
        }
      }
    }
  }
}
